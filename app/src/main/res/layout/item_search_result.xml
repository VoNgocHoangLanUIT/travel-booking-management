<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?attr/selectableItemBackground">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="240dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/imgRoomResult"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/dalat_1" />

            <TextView
                android:id="@+id/tvBadgeResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:background="@drawable/bg_airbnb_badge"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="Được khách yêu thích"
                android:textColor="#111111"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imgHeartResult"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:src="@drawable/ic_heart_outline" />

            <!-- Page indicator (simplified) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">
                <View android:layout_width="6dp" android:layout_height="6dp" android:layout_margin="2dp" android:background="@drawable/bg_airbnb_circle_light" />
                <View android:layout_width="6dp" android:layout_height="6dp" android:layout_margin="2dp" android:alpha="0.6" android:background="@drawable/bg_airbnb_circle_light" />
                <View android:layout_width="6dp" android:layout_height="6dp" android:layout_margin="2dp" android:alpha="0.6" android:background="@drawable/bg_airbnb_circle_light" />
            </LinearLayout>

        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvTitleResult"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nơi ở tại Đà Lạt"
            android:textColor="#111111"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRatingResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="★ 5,0 (9)"
            android:textColor="#111111"
            android:textSize="15sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvMetaResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Căn hộ Studio áp mái view thành phố"
        android:textColor="#717171"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvDetailsResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="1 phòng ngủ · 1 giường"
        android:textColor="#717171"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvPriceResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="đ675.848 cho 1 đêm"
        android:textColor="#111111"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>